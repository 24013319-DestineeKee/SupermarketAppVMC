<%- include('partials/header', {
  title: 'My Orders - Supermarket App',
  user,
  navLinks: [
    { href: '/my-orders', label: 'My Orders' },
    { href: '/shopping', label: 'Shopping' },
    { href: '/cart', label: 'Cart' },
    { href: '/logout', label: 'Logout' }
  ]
}) %>

<div class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">My Orders</h2>
    <a href="/my-orders" class="btn btn-outline-primary btn-sm">Refresh</a>
  </div>

  <% if (messages && messages.error && messages.error.length) { %>
    <div class="alert alert-danger">
      <% messages.error.forEach(function(msg){ %><div><%= msg %></div><% }); %>
    </div>
  <% } %>
  <% if (messages && messages.success && messages.success.length) { %>
    <div class="alert alert-success">
      <% messages.success.forEach(function(msg){ %><div><%= msg %></div><% }); %>
    </div>
  <% } %>

  <% if (!orders || !orders.length) { %>
    <div class="alert alert-info">You have no orders yet.</div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table table-striped align-middle">
        <thead>
          <tr>
            <th>ID</th>
            <th>Status</th>
            <th>Total</th>
            <th>Items</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(function(order){ %>
            <tr>
              <td>#<%= order.id %></td>
              <td><span class="badge bg-secondary text-uppercase"><%= order.status || 'pending' %></span></td>
              <td>$<%= (order.totalAmount || 0).toFixed(2) %></td>
              <td>
                <% const count = (order.items && order.items.length) ? order.items.length : 0; %>
                <button class="btn btn-sm btn-link p-0" type="button" data-bs-toggle="collapse" data-bs-target="#my-items-<%= order.id %>">
                  <%= count %> item<%= count === 1 ? '' : 's' %>
                </button>
              </td>
              <td class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#my-items-<%= order.id %>">View Details</button>
                <a class="btn btn-sm btn-outline-primary" href="/invoice/<%= order.id %>">Invoice</a>
                <% if ((order.status || '').toLowerCase() !== 'completed') { %>
                  <form action="/orders/<%= order.id %>/complete" method="POST" onsubmit="return confirm('Mark this order as completed?');">
                    <button type="submit" class="btn btn-sm btn-success">Confirm Delivery</button>
                  </form>
                <% } %>
              </td>
            </tr>
            <tr class="collapse" id="my-items-<%= order.id %>">
              <td colspan="5">
                <% if (!order.items || !order.items.length) { %>
                  <div class="text-muted">No items.</div>
                <% } else { %>
                  <div class="table-responsive">
                    <table class="table table-sm mb-0">
                      <thead>
                        <tr>
                          <th>Product</th>
                          <th>Image</th>
                          <th>Quantity</th>
                          <th>Price</th>
                          <th>Line Total</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% order.items.forEach(function(item){ %>
                          <tr>
                            <td><%= item.productName || ('Product #' + item.productId) %></td>
                            <td>
                              <% if (item.image) { %>
                                <img src="/images/<%= item.image %>" alt="<%= item.productName %>" style="width: 50px;" loading="lazy" onerror="this.classList.add('d-none'); this.insertAdjacentHTML('afterend','<span class=&quot;text-muted&quot;>N/A</span>');">
                              <% } else { %>
                                <span class="text-muted">N/A</span>
                              <% } %>
                            </td>
                            <td><%= item.quantity %></td>
                            <td>$<%= Number(item.price || 0).toFixed(2) %></td>
                            <td>$<%= (Number(item.price || 0) * Number(item.quantity || 0)).toFixed(2) %></td>
                          </tr>
                        <% }); %>
                      </tbody>
                    </table>
                  </div>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Your Cart</title>
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Supermarket App</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/shopping">Continue Shopping</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <h2 class="mb-3">Your Cart</h2>
    <p>Welcome, <%= user.username %> (<%= user.role %>)</p>

    <% if (messages && messages.error && messages.error.length) { %>
      <div class="alert alert-danger">
        <% messages.error.forEach(function(msg){ %>
          <div><%= msg %></div>
        <% }) %>
      </div>
    <% } %>
    <% if (messages && messages.success && messages.success.length) { %>
      <div class="alert alert-success">
        <% messages.success.forEach(function(msg){ %>
          <div><%= msg %></div>
        <% }) %>
      </div>
    <% } %>

    <% if (!cart || cart.length === 0) { %>
      <div class="alert alert-info">Your cart is empty. <a href="/shopping">Start shopping</a>.</div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-striped align-middle">
          <thead>
            <tr>
              <th>Product</th>
              <th>Price</th>
              <th>Discount</th>
              <th>Final Price</th>
              <th>Quantity</th>
              <th>Total</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% cart.forEach(function(item){ %>
              <tr>
                <td>
                  <div class="d-flex align-items-center">
                    <img src="/images/<%= item.image %>" alt="<%= item.productName %>" width="60" class="me-3">
                    <div>
                      <div class="fw-bold"><%= item.productName %></div>
                    </div>
                  </div>
                </td>
                <td>$<%= item.unitPrice.toFixed(2) %></td>
                <td><%= item.discount %>%</td>
                <td>$<%= item.discountedPrice.toFixed(2) %></td>
                <td>
                  <form class="d-flex" action="/cart/update/<%= item.cartItemId %>" method="POST">
                    <input type="number" name="quantity" class="form-control me-2" min="0" value="<%= item.quantity %>" style="max-width: 90px;">
                    <button type="submit" class="btn btn-sm btn-primary">Update</button>
                  </form>
                </td>
                <td>$<%= item.lineTotal.toFixed(2) %></td>
                <td>
                  <form action="/cart/remove/<%= item.cartItemId %>" method="POST">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <div class="text-end">
        <h4>Cart Total: $<%= cartTotal.toFixed(2) %></h4>
      </div>
    <% } %>
  </div>
</body>
</html>

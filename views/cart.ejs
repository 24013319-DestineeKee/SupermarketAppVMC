<%- include('partials/header', {
  title: 'Your Cart - Supermarket App',
  user,
  navLinks: [
    { href: '/my-orders', label: 'My Orders' },
    { href: '/shopping', label: 'Continue Shopping' },
    { href: '/logout', label: 'Logout' }
  ]
}) %>

<div class="container mt-4">
  <h2 class="mb-3">Your Cart</h2>
  <p>Welcome, <%= user.displayName || user.username || user.email %> (<%= user.role %>)</p>

  <% if (messages && messages.error && messages.error.length) { %>
    <div class="alert alert-danger">
      <% messages.error.forEach(function(msg){ %>
        <div><%= msg %></div>
      <% }) %>
    </div>
  <% } %>
    <% if (messages && messages.success && messages.success.length) { %>
      <div class="alert alert-success">
        <% messages.success.forEach(function(msg){ %>
          <div><%= msg %></div>
        <% }) %>
      </div>
    <% } %>

    <% if (!cart || cart.length === 0) { %>
      <div class="alert alert-info">Your cart is empty. <a href="/shopping">Start shopping</a>.</div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-striped align-middle">
          <thead>
            <tr>
              <th>Product</th>
              <th>Price</th>
              <th>Discount</th>
              <th>Final Price</th>
              <th>Quantity</th>
              <th>Total</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% cart.forEach(function(item){ %>
              <tr>
                <td>
                  <div class="d-flex align-items-center">
                    <% if (item.image) { %>
                      <img src="/images/<%= item.image %>" alt="<%= item.productName %>" width="60" class="me-3" loading="lazy" onerror="this.classList.add('d-none'); this.insertAdjacentHTML('afterend','<span class=&quot;text-muted&quot;>No image</span>');">
                    <% } else { %>
                      <span class="text-muted me-3">No image</span>
                    <% } %>
                    <div>
                      <div class="fw-bold"><%= item.productName %></div>
                    </div>
                  </div>
                </td>
                <td>$<%= item.unitPrice.toFixed(2) %></td>
                <td><%= item.discount %>%</td>
                <td>$<%= item.discountedPrice.toFixed(2) %></td>
                <td>
                  <form class="d-flex" action="/cart/update/<%= item.cartItemId %>" method="POST">
                    <input type="number" name="quantity" class="form-control me-2" min="0" value="<%= item.quantity %>" style="max-width: 90px;">
                    <button type="submit" class="btn btn-sm btn-primary">Update</button>
                  </form>
                </td>
                <td>$<%= item.lineTotal.toFixed(2) %></td>
                <td>
                  <form action="/cart/remove/<%= item.cartItemId %>" method="POST">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-3">
        <h4 class="mb-0">Cart Total: $<%= cartTotal.toFixed(2) %></h4>
        <a href="/checkout" class="btn btn-success btn-lg">Proceed to Checkout</a>
      </div>
    <% } %>
  </div>

<%- include('partials/footer') %>

<%- include('partials/header', {
  title: 'Edit Product - Supermarket App',
  user,
  navLinks: [
    { href: '/inventory', label: 'Inventory' },
    { href: '/addProduct', label: 'Add new product' },
    { href: '/logout', label: 'Logout' }
  ]
}) %>

<style>
  .page-shell { max-width: 760px; margin: 32px auto 48px; padding: 0 16px; }
  .panel { background: #ffffff; border: 1px solid #e5e7eb; border-radius: 16px; box-shadow: 0 12px 32px rgba(16,24,40,0.08); padding: 24px; }
  .helper-text { color: #6b7280; }
</style>

<div class="page-shell">
  <div class="panel">
    <h2 class="mb-1 text-center">Update Product</h2>
    <p class="helper-text text-center mb-4">Adjust pricing, stock, or the product image.</p>
    <% if (product) { %> 
      <form action="/editProduct/<%= product.id %>" method="POST" enctype="multipart/form-data">
        <div class="mb-3">
          <label for="name" class="form-label">Product Name</label>
          <input type="text" id="name" name="name" class="form-control" value="<%= product.productName %>" required>
        </div>

        <div class="mb-3">
          <label for="quantity" class="form-label">Quantity</label>
          <input type="number" id="quantity" name="quantity" min="0" step="1" class="form-control" value="<%= product.quantity %>" required>
        </div>

        <div class="mb-3">
          <label for="price" class="form-label">Price</label>
          <input type="number" id="price" name="price" min="0" step="0.01" class="form-control" value="<%= product.price %>" required>
        </div>

        <div class="mb-3">
          <label class="form-label" for="image">Current Image</label>
          <input type="text" name="currentImage" class="form-control mb-2" value="<%= product.image %>" readonly>
          <% if (product.image) { %>
            <img src="/images/<%= product.image %>" class="product-thumb" alt="<%= product.productName %>">
          <% } else { %>
            <span class="text-muted d-block">No image</span>
          <% } %>
        </div>
        
        <div class="mb-4">
          <label class="form-label" for="image">New Image</label>
          <input type="file" id="image" name="image" accept="image/*" class="form-control">
        </div>

        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary">Update Product</button>
          <a href="/" class="btn btn-secondary">Back</a>
        </div>
      </form>
    <% } else { %>
      <p class="text-center mb-0">No product found.</p>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
